# BLACKBULL Trading Assistant — environment template.
# Copy to `.env` (same dir) and fill values. NEVER commit `.env` itself.

# === LLM / AI ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === MCP browser bridge (TradingView) ===
# URL to the MCP server that drives the headless TradingView browser.
MCP_TOKEN=
CHROME_BIN=/usr/bin/google-chrome

# === MongoDB ===
# Connection string for the persisted state (users, broker accounts, history).
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# === Auth ===
# Random ≥32-byte string. Generate with: openssl rand -hex 32
JWT_SECRET=

# === MetaApi / CopyFactory ===
# Long-lived JWT from https://app.metaapi.cloud/token
METAAPI_TOKEN=
# London / new-york / etc — match your account's region.
METAAPI_REGION=london
# CopyFactory PROVIDER MT account id (anchor for the strategy).
METAAPI_MASTER_ACCOUNT_ID=
# 1-8 alphanumeric chars; the CopyFactory strategy that fans signals out.
METAAPI_STRATEGY_ID=BLBL

# === Live signal fan-out ===
# false = paper-mode (logs only); true = actually PUT signals to CopyFactory.
COPY_LIVE=false
